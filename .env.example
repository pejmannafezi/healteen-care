# ──────────────────────────────────────────────────────────────
# Healteen Care — environment variables
# Copy this file to ".env.local" and fill in real values.
# NEVER commit .env.local. Keys without NEXT_PUBLIC_ are server-only.
# ──────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # SERVER ONLY — full DB access, never expose to browser

# Stripe (Dashboard → Developers → API keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=                  # SERVER ONLY
STRIPE_WEBHOOK_SECRET=              # SERVER ONLY — from `stripe listen` / dashboard webhook

# Anthropic (Claude — powers the 3 AI agents)
# Named HEALTEEN_ANTHROPIC_KEY locally to avoid colliding with an empty
# ANTHROPIC_API_KEY some shells pre-define. On Vercel either name works.
HEALTEEN_ANTHROPIC_KEY=             # SERVER ONLY

# Resend (transactional email)
RESEND_API_KEY=                     # SERVER ONLY
EMAIL_FROM="Healteen Care <info@healteencare.com>"

# Shippo (shipping + tracking) — added in M5
SHIPPO_API_TOKEN=                   # SERVER ONLY

# Google Calendar (consultation meeting links) — added in M6
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=

# Upstash Redis (rate limiting) — added in M10
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
