# Optional overrides. The app already has working public defaults baked into
# lib/supabase.ts (the publishable key + URL are public and RLS-protected).
# Copy this file to ".env" only if you want to point the app at a different
# Supabase project.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
